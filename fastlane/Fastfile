# Fastlane pipeline for building and shipping FinancialPlanner to TestFlight.
#
# Mac-free by design: this runs on a GitHub Actions macOS runner. Authentication
# uses an App Store Connect API key; signing uses `match`. All Apple-specific
# values come from environment variables (GitHub secrets) — see
# docs/TESTFLIGHT_SETUP.md for the full setup checklist.

default_platform(:ios)

PROJECT = "FinancialPlanner.xcodeproj"
SCHEME  = "FinancialPlanner"
APP_ID  = ENV["APP_IDENTIFIER"] || "com.presight.financialplanner"

# Builds an App Store Connect API key object from env / secrets.
def asc_api_key
  app_store_connect_api_key(
    key_id:      ENV["ASC_KEY_ID"],
    issuer_id:   ENV["ASC_ISSUER_ID"],
    key_content: ENV["ASC_KEY_P8"]   # raw .p8 contents
  )
end

platform :ios do
  # This repo's .xcodeproj is generated by XcodeGen — regenerate before building.
  before_all do
    sh("command -v xcodegen >/dev/null 2>&1 && (cd .. && xcodegen generate) || echo 'xcodegen not found; using committed project'")
  end

  desc "Create/refresh the distribution cert + provisioning profile (run once, manually)"
  lane :certificates do
    match(type: "appstore", app_identifier: APP_ID, readonly: false, api_key: asc_api_key)
  end

  desc "Build a Release archive and upload it to TestFlight"
  lane :beta do
    key = asc_api_key

    # Fetch signing assets created by `certificates` (read-only in CI).
    match(type: "appstore", app_identifier: APP_ID, readonly: true, api_key: key)

    # Each upload needs a unique, increasing build number.
    next_build = (latest_testflight_build_number(api_key: key, app_identifier: APP_ID) rescue 0) + 1
    increment_build_number(build_number: next_build, xcodeproj: PROJECT)

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      xcargs: "DEVELOPMENT_TEAM=#{ENV['TEAM_ID']} CODE_SIGN_STYLE=Manual",
      export_options: {
        provisioningProfiles: {
          APP_ID => "match AppStore #{APP_ID}"
        }
      }
    )

    upload_to_testflight(
      api_key: key,
      app_identifier: APP_ID,
      skip_waiting_for_build_processing: true
    )
  end
end
